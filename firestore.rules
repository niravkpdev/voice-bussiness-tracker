rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasOwner(userId) {
      return request.resource.data.ownerUid == userId
        || request.resource.data.ownerId == userId
        || request.resource.data.userId == userId;
    }

    function safeText(field, maxLength) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLength);
    }

    function safeNumber(field, min, max) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is number
          && request.resource.data[field] >= min
          && request.resource.data[field] <= max);
    }

    function safeDateString(field) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string
          && request.resource.data[field].matches('^\\d{4}-\\d{2}-\\d{2}$'));
    }

    function safeUpdatedAt() {
      return !('updatedAt' in request.resource.data)
        || request.resource.data.updatedAt == request.time;
    }

    function ownsExisting(userId) {
      return resource.data.ownerUid == userId
        || resource.data.ownerId == userId
        || resource.data.userId == userId;
    }

    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'ownerName', 'businessName', 'role', 'provider',
          'emailVerified', 'loginAt', 'updatedAt'
        ])
        && request.resource.data.uid == userId
        && safeText('email', 180)
        && safeText('ownerName', 140)
        && safeText('businessName', 180)
        && safeText('role', 40)
        && (!('emailVerified' in request.resource.data) || request.resource.data.emailVerified is bool)
        && safeUpdatedAt();

      match /transactions/{documentId} {
        allow read, delete: if isOwner(userId) && ownsExisting(userId);
        allow create, update: if isOwner(userId)
          && hasOwner(userId)
          && request.resource.data.keys().hasOnly([
            'id', 'transactionId', 'ownerUid', 'ownerId', 'userId', 'date',
            'dateTime', 'type', 'amount', 'category', 'customer', 'narration',
            'notes', 'lines', 'source', 'confidence', 'needsConfirmation',
            'updatedAt'
          ])
          && safeText('id', 80)
          && safeText('transactionId', 80)
          && safeText('type', 40)
          && safeText('category', 120)
          && safeText('customer', 120)
          && safeText('dateTime', 80)
          && safeText('narration', 300)
          && safeText('notes', 500)
          && safeText('source', 40)
          && safeNumber('amount', 0, 100000000)
          && safeNumber('confidence', 0, 1)
          && safeDateString('date')
          && (!('lines' in request.resource.data) || request.resource.data.lines is list)
          && (!('needsConfirmation' in request.resource.data) || request.resource.data.needsConfirmation is bool)
          && safeUpdatedAt();
      }

      match /customers/{documentId} {
        allow read, delete: if isOwner(userId) && ownsExisting(userId);
        allow create, update: if isOwner(userId)
          && hasOwner(userId)
          && request.resource.data.keys().hasOnly([
            'id', 'customerId', 'ownerUid', 'ownerId', 'userId', 'businessId',
            'name', 'phone', 'mobile', 'email', 'address', 'gst',
            'openingBalance', 'outstandingAmount', 'outstanding', 'type',
            'notes', 'createdAt', 'updatedAt'
          ])
          && safeText('id', 80)
          && safeText('customerId', 80)
          && safeText('businessId', 80)
          && safeText('name', 120)
          && safeText('phone', 24)
          && safeText('mobile', 24)
          && safeText('email', 180)
          && safeText('address', 240)
          && safeText('gst', 32)
          && safeText('type', 20)
          && safeText('notes', 500)
          && safeText('createdAt', 40)
          && safeNumber('openingBalance', -100000000, 100000000)
          && safeNumber('outstandingAmount', -100000000, 100000000)
          && safeNumber('outstanding', -100000000, 100000000)
          && safeUpdatedAt();
      }

      match /suppliers/{documentId} {
        allow read, delete: if isOwner(userId) && ownsExisting(userId);
        allow create, update: if isOwner(userId)
          && hasOwner(userId)
          && request.resource.data.keys().hasOnly([
            'id', 'supplierId', 'ownerUid', 'ownerId', 'userId', 'businessId',
            'name', 'phone', 'mobile', 'email', 'address', 'gst',
            'openingBalance', 'payableAmount', 'type', 'notes', 'createdAt',
            'updatedAt'
          ])
          && safeText('id', 80)
          && safeText('supplierId', 80)
          && safeText('businessId', 80)
          && safeText('name', 120)
          && safeText('phone', 24)
          && safeText('mobile', 24)
          && safeText('email', 180)
          && safeText('address', 240)
          && safeText('gst', 32)
          && safeText('type', 20)
          && safeText('notes', 500)
          && safeText('createdAt', 40)
          && safeNumber('openingBalance', -100000000, 100000000)
          && safeNumber('payableAmount', -100000000, 100000000)
          && safeUpdatedAt();
      }

      match /inventory/{documentId} {
        allow read, delete: if isOwner(userId) && ownsExisting(userId);
        allow create, update: if isOwner(userId)
          && hasOwner(userId)
          && request.resource.data.keys().hasOnly([
            'id', 'itemId', 'ownerUid', 'ownerId', 'userId', 'businessId', 'name',
            'category', 'sku', 'image', 'purchasePrice', 'sellingPrice',
            'currentStock', 'minStock', 'unit', 'createdAt', 'updatedAt'
          ])
          && safeText('id', 80)
          && safeText('itemId', 80)
          && safeText('businessId', 80)
          && safeText('name', 120)
          && safeText('category', 80)
          && safeText('sku', 60)
          && safeText('image', 200000)
          && safeText('unit', 24)
          && safeNumber('purchasePrice', 0, 100000000)
          && safeNumber('sellingPrice', 0, 100000000)
          && safeNumber('currentStock', 0, 100000000)
          && safeNumber('minStock', 0, 100000000)
          && safeUpdatedAt();
      }

      match /reports/{documentId} {
        allow read, delete: if isOwner(userId) && ownsExisting(userId);
        allow create, update: if isOwner(userId)
          && hasOwner(userId)
          && request.resource.data.keys().hasOnly([
            'id', 'ownerUid', 'ownerId', 'userId', 'title', 'type',
            'dateRange', 'summary', 'metrics', 'createdAt', 'updatedAt'
          ])
          && safeText('id', 80)
          && safeText('title', 160)
          && safeText('type', 80)
          && safeText('summary', 1000)
          && (!('dateRange' in request.resource.data) || request.resource.data.dateRange is map)
          && (!('metrics' in request.resource.data) || request.resource.data.metrics is map)
          && safeUpdatedAt();
      }

      match /settings/{documentId} {
        allow read, delete: if isOwner(userId) && ownsExisting(userId);
        allow create, update: if isOwner(userId)
          && hasOwner(userId)
          && request.resource.data.keys().hasOnly([
            'id', 'ownerUid', 'ownerId', 'userId', 'theme', 'language',
            'notifications', 'voice', 'backup', 'security', 'name', 'tagline',
            'logo', 'owner', 'email', 'phone', 'address', 'gstin', 'updatedAt'
          ])
          && documentId == 'profile'
          && safeText('id', 80)
          && safeText('theme', 20)
          && safeText('language', 20)
          && safeText('name', 140)
          && safeText('tagline', 160)
          && safeText('logo', 200000)
          && safeText('owner', 120)
          && safeText('email', 180)
          && safeText('phone', 24)
          && safeText('address', 240)
          && safeText('gstin', 32)
          && (!('notifications' in request.resource.data) || request.resource.data.notifications is map)
          && (!('voice' in request.resource.data) || request.resource.data.voice is map)
          && (!('backup' in request.resource.data) || request.resource.data.backup is map)
          && (!('security' in request.resource.data) || request.resource.data.security is map)
          && safeUpdatedAt();
      }
    }

    match /publicLegal/{documentId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
